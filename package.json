{
  "name": "@faruhe/tkcli",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Project harness generator for AI-assisted development — scaffold, compose, and configure across 14 stacks",
  "type": "module",
  "bin": {
    "tk": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "scaffold",
    "ai",
    "toolkit",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "inquirer": "^12.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
