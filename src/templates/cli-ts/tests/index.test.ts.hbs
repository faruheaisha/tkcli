import { describe, it, expect } from 'vitest';
import { execSync } from 'child_process';
import { resolve } from 'path';
import { tmpdir } from 'os';
import { writeFileSync } from 'fs';
import { join } from 'path';

const cli = resolve(__dirname, '../src/index.ts');

function run(args: string): string {
  return execSync(`npx tsx ${cli} ${args}`, { encoding: 'utf-8' }).trim();
}

describe('{{projectName}} CLI', () => {
  it('parses and formats a JSON file', () => {
    const tmpFile = join(tmpdir(), `test-${Date.now()}.json`);
    writeFileSync(tmpFile, '{"name":"test","value":42}', 'utf-8');
    const out = run(`json "${tmpFile}"`);
    expect(out).toContain('"name": "test"');
    expect(out).toContain('"value": 42');
  });

  it('counts words in text', () => {
    const out = run('count "hello world"');
    expect(out).toContain('Words: 2');
    expect(out).toContain('Characters: 11');
  });

  it('counts empty text', () => {
    const out = run('count ""');
    expect(out).toContain('Words: 0');
  });

  it('handles missing file error', () => {
    try {
      run('json nonexistent.json');
      expect.fail('Should have thrown');
    } catch (e: any) {
      expect(e.stderr || e.stdout).toBeTruthy();
      expect(e.status).toBe(1);
    }
  });

  it('handles missing required argument', () => {
    try {
      run('');
      expect.fail('Should have thrown');
    } catch (e: any) {
      expect(e.status).toBe(1);
    }
  });
});
