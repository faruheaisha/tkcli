import { describe, it, expect, vi } from 'vitest';
import supertest from 'supertest';
import { createApp } from '../src/index.js';

const app = createApp();

describe('GET /health', () => {
  it('returns ok with timestamp', async () => {
    const res = await supertest(app).get('/health');
    expect(res.status).toBe(200);
    expect(res.body.status).toBe('ok');
    expect(res.body.timestamp).toBeDefined();
  });
});

describe('POST /api/v1/hello', () => {
  it('greets the user', async () => {
    const res = await supertest(app)
      .post('/api/v1/hello')
      .send({ name: 'Express' });
    expect(res.status).toBe(200);
    expect(res.body.success).toBe(true);
    expect(res.body.data.message).toBe('Hello, Express!');
  });

  it('rejects empty name', async () => {
    const res = await supertest(app)
      .post('/api/v1/hello')
      .send({ name: '' });
    expect(res.status).toBe(400);
    expect(res.body.details).toBeDefined();
  });

  it('rejects missing body', async () => {
    const res = await supertest(app)
      .post('/api/v1/hello')
      .send({});
    expect(res.status).toBe(400);
  });
});

describe('404 handler', () => {
  it('returns 404 for unknown routes', async () => {
    const res = await supertest(app).get('/nonexistent');
    expect(res.status).toBe(404);
    expect(res.body.error).toBe('Not found');
  });
});

describe('Error handler', () => {
  it('handles thrown errors', async () => {
    const res = await supertest(app).get('/api/v1/error-example');
    expect(res.status).toBe(400);
    expect(res.body.success).toBe(false);
  });
});
