import 'package:flutter_test/flutter_test.dart';
import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:{{projectName}}/counter/counter.dart';
import 'package:{{projectName}}/counter/view/counter_body.dart';

void main() {
  group('CounterBody', () {
    testWidgets('renders with initial count 0', (tester) async {
      await tester.pumpWidget(
        const ProviderScope(
          child: MaterialApp(home: CounterBody()),
        ),
      );
      expect(find.text('0'), findsOneWidget);
    });

    testWidgets('increment increases count', (tester) async {
      await tester.pumpWidget(
        const ProviderScope(
          child: MaterialApp(home: CounterBody()),
        ),
      );
      await tester.tap(find.byIcon(Icons.add));
      await tester.pumpAndSettle();
      expect(find.text('1'), findsOneWidget);
    });
  });
}
