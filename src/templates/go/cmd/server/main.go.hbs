package main

import (
	"log"
	"net/http"
	"os"
	"os/signal"
	"syscall"

	"github.com/yourusername/{{projectName}}/internal/app"
	"github.com/yourusername/{{projectName}}/internal/foundation/logger"
)

func main() {
	logger := logger.New(os.Stdout, "{{projectName}}")

	addr := os.Getenv("ADDR")
	if addr == "" {
		addr = ":8080"
	}

	srv := app.New(addr, logger)

	go func() {
		log.Printf("🚀 {{projectName}} running on http://0.0.0.0%s", addr)
		if err := srv.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			log.Fatalf("Server error: %v", err)
		}
	}()

	quit := make(chan os.Signal, 1)
	signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)
	<-quit
	log.Println("Shutting down server...")
}
