package app

import (
	"net/http"

	"github.com/gin-gonic/gin"
	"github.com/yourusername/{{projectName}}/internal/business/user"
	"github.com/yourusername/{{projectName}}/internal/foundation/logger"
)

// New creates an *http.Server with all routes and middleware configured.
func New(addr string, log *logger.Logger) *http.Server {
	gin.SetMode(gin.ReleaseMode)
	r := gin.New()
	r.Use(gin.Recovery())
	r.Use(logger.Middleware(log))

	// Health
	r.GET("/health", HealthHandler)

	// Business routes
	userHandler := user.NewHandler()
	v1 := r.Group("/api/v1")
	{
		v1.GET("/users", userHandler.List)
		v1.POST("/users", userHandler.Create)
	}

	return &http.Server{
		Addr:    addr,
		Handler: r,
	}
}

// HealthHandler returns service health status.
func HealthHandler(c *gin.Context) {
	c.JSON(http.StatusOK, gin.H{
		"status": "ok",
	})
}
