name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.29'
      - run: flutter pub get
      - run: flutter test --coverage --test-randomize-ordering-seed random
      - run: flutter analyze
