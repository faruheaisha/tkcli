#!/usr/bin/env node
import { McpServer } from '@modelcontextprotocol/sdk/server/mcp.js';
import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';
import { greet, greetInputSchema } from './tools.js';

const server = new McpServer({
  name: '{{projectName}}',
  version: '0.1.0',
});

// Register a tool. Add more with server.registerTool(...).
server.registerTool(
  'greet',
  {
    title: 'Greet',
    description: 'Return a friendly greeting for the given name',
    inputSchema: greetInputSchema,
  },
  async ({ name }) => ({
    content: [{ type: 'text', text: greet(name) }],
  }),
);

async function main(): Promise<void> {
  // MCP talks over stdio: stdout is the protocol channel, so logs MUST go to stderr.
  const transport = new StdioServerTransport();
  await server.connect(transport);
  console.error('{{projectName}} MCP server running on stdio');
}

main().catch((err) => {
  console.error('Fatal error starting MCP server:', err);
  process.exit(1);
});
