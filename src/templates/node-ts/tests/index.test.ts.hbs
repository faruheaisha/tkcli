import { describe, it, expect, beforeAll, afterAll } from 'vitest';
import { server } from '../src/index.js';

const TEST_PORT = 3123;

beforeAll(() => {
  return new Promise<void>((resolve) => {
    server.listen(TEST_PORT, '127.0.0.1', () => resolve());
  });
});

afterAll(() => {
  return new Promise<void>((resolve) => {
    server.close(() => resolve());
  });
});

describe('GET /', () => {
  it('returns 200 with status ok', async () => {
    const res = await fetch(`http://127.0.0.1:${TEST_PORT}/`);
    expect(res.status).toBe(200);
    const body = await res.json() as { status: string };
    expect(body.status).toBe('ok');
  });

  it('returns uptime as a number', async () => {
    const res = await fetch(`http://127.0.0.1:${TEST_PORT}/`);
    const body = await res.json() as { uptime: number };
    expect(typeof body.uptime).toBe('number');
  });

  it('sets Content-Type to application/json', async () => {
    const res = await fetch(`http://127.0.0.1:${TEST_PORT}/`);
    expect(res.headers.get('content-type')).toBe('application/json');
  });

  it('returns 404 for unknown routes', async () => {
    const res = await fetch(`http://127.0.0.1:${TEST_PORT}/nonexistent`);
    expect(res.status).toBe(404);
  });

  it('rejects POST with 404 (only GET / is defined)', async () => {
    const res = await fetch(`http://127.0.0.1:${TEST_PORT}/`, { method: 'POST' });
    expect(res.status).toBe(404);
  });
});
