import { describe, it, expect } from "vitest";

describe("example", () => {
  it("should pass a sanity check", () => {
    expect(1 + 1).toBe(2);
  });

  it("should render home page with heading", async () => {
    const { mount } = await import("@vue/test-utils");
    const index = await import("../app/pages/index.vue");
    const wrapper = mount(index.default);
    expect(wrapper.find("h1").exists()).toBe(true);
    expect(wrapper.html()).toContain("h1");
  });

  it("should render home page with a link or navigation", async () => {
    const { mount } = await import("@vue/test-utils");
    const index = await import("../app/pages/index.vue");
    const wrapper = mount(index.default);
    expect(wrapper.find("a").exists() || wrapper.find("button").exists() || wrapper.html().length > 0).toBe(true);
  });

  it("should render with correct project name placeholder", async () => {
    const { mount } = await import("@vue/test-utils");
    const index = await import("../app/pages/index.vue");
    const wrapper = mount(index.default);
    expect(wrapper.text()).toContain("h1");
  });

  it("should use useAsyncData for server data", async () => {
    const { mount } = await import("@vue/test-utils");
    const index = await import("../app/pages/index.vue");
    const wrapper = mount(index.default);
    // Verify the component mounts without error (useAsyncData is mocked by Nuxt test utils)
    expect(wrapper.exists()).toBe(true);
  });
});
