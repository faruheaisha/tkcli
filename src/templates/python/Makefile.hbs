.PHONY: qa test lint typecheck clean

qa: lint typecheck test                       ## Run all checks (lint + type-check + test)

test:                                          ## Run tests with coverage
	pytest --cov --cov-report=term-missing -x

lint:                                          ## Lint with Ruff
	ruff check src/

typecheck:                                     ## Type-check with mypy (strict)
	mypy src/

clean:                                         ## Remove cache artifacts (Windows-compatible)
	-if exist .pytest_cache rmdir /s /q .pytest_cache
	-if exist __pycache__ rmdir /s /q __pycache__
	-if exist .mypy_cache rmdir /s /q .mypy_cache
	-if exist .coverage del /f /q .coverage
	-if exist htmlcov rmdir /s /q htmlcov
	-for /r /d %i in (__pycache__) do if exist "%i" rmdir /s /q "%i"
