"""Tests for {{projectName}}."""

from typer.testing import CliRunner

from {{projectName}}.cli import app

runner = CliRunner()


def test_imports() -> None:
    """Package-level imports work correctly."""
    from {{projectName}} import __version__
    assert __version__ == "0.1.0"


def test_greet_default() -> None:
    """The ``greet`` command prints the default greeting."""
    result = runner.invoke(app, ["greet"])
    assert result.exit_code == 0
    assert "Hello, World!" in result.output


def test_greet_custom_name() -> None:
    """The ``greet`` command accepts a ``--name`` option."""
    result = runner.invoke(app, ["greet", "--name", "Alice"])
    assert result.exit_code == 0
    assert "Hello, Alice!" in result.output


def test_add_numbers() -> None:
    """Summing integers works."""
    result = runner.invoke(app, ["add", "1", "2", "3", "4", "5"])
    assert result.exit_code == 0
    assert "Sum: 15" in result.output


def test_add_single() -> None:
    """A single number is summed correctly."""
    result = runner.invoke(app, ["add", "42"])
    assert result.exit_code == 0
    assert "Sum: 42" in result.output


def test_add_empty() -> None:
    """Omitting numbers raises an error."""
    result = runner.invoke(app, ["add"])
    assert result.exit_code != 0


def test_help() -> None:
    """--help shows available commands."""
    result = runner.invoke(app, ["--help"])
    assert result.exit_code == 0
    assert "greet" in result.output
    assert "add" in result.output
