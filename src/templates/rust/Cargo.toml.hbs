[package]
name = "{{projectName}}"
version = "0.1.0"
edition = "2021"
description = "{{description}}"

[dependencies]
clap = { version = "4", features = ["derive", "env"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
toml = "0.8"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }

[dev-dependencies]
clap_complete = "4"
assert_cmd = "2"
predicates = "3"
