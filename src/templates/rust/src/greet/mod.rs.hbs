pub fn greet(name: &str) -> String {
    format!("Hello, {name}!")
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_greet_default() {
        assert_eq!(greet("World"), "Hello, World!");
    }

    #[test]
    fn test_greet_custom() {
        assert_eq!(greet("Karpathy"), "Hello, Karpathy!");
    }

    #[test]
    fn test_greet_empty() {
        assert_eq!(greet(""), "Hello, !");
    }
}
