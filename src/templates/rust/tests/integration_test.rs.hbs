use assert_cmd::Command;

#[test]
fn test_greet_lib() {
    assert_eq!({{crate_name}}::greet::greet("World"), "Hello, World!");
    assert_eq!({{crate_name}}::greet::greet("Karpathy"), "Hello, Karpathy!");
}

#[test]
fn test_cli_default_name() {
    let mut cmd = Command::cargo_bin("{{projectName}}").unwrap();
    cmd.assert().success().stdout("Hello, World!\n");
}

#[test]
fn test_cli_custom_name() {
    let mut cmd = Command::cargo_bin("{{projectName}}").unwrap();
    cmd.arg("Alice");
    cmd.assert().success().stdout("Hello, Alice!\n");
}

#[test]
fn test_cli_version_flag() {
    let mut cmd = Command::cargo_bin("{{projectName}}").unwrap();
    cmd.arg("--version");
    cmd.assert().success();
}

#[test]
fn test_cli_config_flag_unknown_file() {
    let mut cmd = Command::cargo_bin("{{projectName}}").unwrap();
    cmd.args(["--config", "/nonexistent/config.toml"]);
    cmd.assert().success().stderr(predicates::str::contains("Warning:"));
}
