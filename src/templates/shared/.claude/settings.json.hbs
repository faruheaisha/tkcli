{
  "permissions": {
    "allow": [
{{#each claudePermissions}}      "{{{this}}}"{{#unless @last}},{{/unless}}
{{/each}}
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(rm:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "echo \"{{stack}} · {{projectName}}\""
  }
}
